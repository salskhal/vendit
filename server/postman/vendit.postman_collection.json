{
  "info": {
    "name": "Vendit — Vending Machine API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "buyerToken", "value": "", "type": "string" },
    { "key": "sellerToken", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (buyer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('buyerToken', json.access_token);",
                  "  pm.collectionVariables.set('userId', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"buyer1\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('sellerToken', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"seller1\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Logout All Sessions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout/all", "host": ["{{baseUrl}}"], "path": ["auth", "logout", "all"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register (buyer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"buyer1\",\n  \"password\": \"password123\",\n  \"role\": \"buyer\"\n}"
            }
          }
        },
        {
          "name": "Register (seller)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"seller1\",\n  \"password\": \"password123\",\n  \"role\": \"seller\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": { "raw": "{{baseUrl}}/user/me", "host": ["{{baseUrl}}"], "path": ["user", "me"] }
          }
        },
        {
          "name": "Update My Account",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user", "{{userId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"buyer1_updated\"\n}"
            }
          }
        },
        {
          "name": "Delete My Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": { "raw": "{{baseUrl}}/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["user", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products", "{{productId}}"] }
          }
        },
        {
          "name": "Create Product (seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('productId', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"Cola\",\n  \"cost\": 35,\n  \"amountAvailable\": 20\n}"
            }
          }
        },
        {
          "name": "Update Product (seller)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products", "{{productId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amountAvailable\": 50,\n  \"cost\": 40\n}"
            }
          }
        },
        {
          "name": "Delete Product (seller)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products", "{{productId}}"] }
          }
        }
      ]
    },
    {
      "name": "Vending",
      "item": [
        {
          "name": "Deposit Coin (buyer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/deposit", "host": ["{{baseUrl}}"], "path": ["deposit"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100\n}"
            }
          }
        },
        {
          "name": "Buy Product (buyer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/buy", "host": ["{{baseUrl}}"], "path": ["buy"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"amount\": 1\n}"
            }
          }
        },
        {
          "name": "Reset Deposit (buyer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": { "raw": "{{baseUrl}}/reset", "host": ["{{baseUrl}}"], "path": ["reset"] }
          }
        }
      ]
    }
  ]
}
